{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 4,
  "final_space": true,

  "console_title_template": "{{if .Root}} ⚡ {{end}}{{.UserName}} ➜ 📁{{.Folder}}",

  "blocks": [
    {
      "type": "rprompt",
      "alignment": "right",
      "segments": [
        {
          "type": "time",
          "style": "plain",
          "background": "#94e2d5",
          "foreground": "#1e1e2e",
          "template": "  {{ .CurrentDate | date .Format }} "
        },
        {
          "type": "executiontime",
          "style": "plain",
          "background": "#313244",
          "foreground": "#a6e3a1",
          "options": {
            "always_enabled": true
          },
          "template": " 󱎫 {{ .FormattedMs }} "
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "session",
          "style": "diamond",
          "background": "#89b4fa",
          "foreground": "#1e1e2e",
          "template": "{{if .Root}}  {{.UserName}} {{else}} {{.UserName}} {{end}}",
          "trailing_diamond": "\ue0b0"
        },
        {
          "type": "path",
          "style": "powerline",
          "background": "#f38ba8",
          "foreground": "#1e1e2e",
          "powerline_symbol": "\ue0b0",
          "template": "  {{ .Path }} ",
          "options": {
            "folder_icon": "",
            "folder_separator_icon": "  ",
            "max_depth": 2,
            "style": "agnoster_short"
          }
        },
        {
          "type": "git",
          "style": "powerline",
          "background": "#a6e3a1",
          "foreground": "#1e1e2e",
          "powerline_symbol": "\ue0b0",
          "template": "  {{ .HEAD }} "
        }
      ]
    }
  ]
}
